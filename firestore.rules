rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Pledges collection - ALL access via Cloud Functions (Admin SDK) only
    // No client-side read/write to prevent PII exposure
    match /pledges/{pledgeId} {
      allow read, write: if false;
    }

    // Stats collection - public read for pledge count (no PII)
    match /stats/{statId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Block access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
